generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Rol {
  ADMIN
  LEGAL
  OPERADOR
  CONSULTOR
}

enum Producto {
  PYME
  PERSONAL
  EXPRESS
  STPB
}

enum TipoAcreditado {
  PF
  PM
}

enum StatusOp {
  PROSPECTO
  ANALISIS
  APROBADA
  ACTIVA
  LIQUIDADA
  EN_MORA
  EJECUTADA
  CANCELADA
}

enum StatusBloque {
  PENDIENTE
  EN_PROCESO
  PRE_AUTORIZADO
  PRE_AUTORIZADO_CONDICIONADO
  EXPEDIENTE_INTEGRADO
  DICTAMEN_VIABLE
  DICTAMEN_VIABLE_CONDICIONADO
  VALIDADO
  OBSERVADO
  FORMALIZADO
  RECHAZADO
  NO_VIABLE
  CERRADO
}

enum StatusPago {
  PENDIENTE
  PAGADO
  PARCIAL
  VENCIDO
  CONDONADO
}

enum StatusDocumento {
  PENDIENTE
  SOLICITADO
  RECIBIDO
  VALIDADO
}

enum TipoDocumento {
  // Acreditado PF
  IDENTIFICACION_OFICIAL
  CURP
  COMPROBANTE_DOMICILIO
  CONSTANCIA_SITUACION_FISCAL
  ESTADOS_CUENTA
  COMPROBANTE_INGRESOS
  ESCRITURAS_INMUEBLE
  CLG
  BOLETAS_PREDIALES
  AVALUO
  POLIZA_SEGURO
  AUTORIZACION_BURO
  // Acreditado PM adicionales
  ACTA_CONSTITUTIVA
  PODERES_NOTARIALES
  IDENTIFICACION_REP_LEGAL
  ALTA_SAT
  ESTADOS_FINANCIEROS
  // Inversionista
  IDENTIFICACION_INVERSIONISTA
  CSF_INVERSIONISTA
  DOMICILIO_INVERSIONISTA
  CLABE_INVERSIONISTA
  CARTA_PROPIETARIO_REAL
  CONVENIO_PARTICIPACION
  // Legal
  CONTRATO_CREDITO
  ESCRITURA_FIDEICOMISO
  CONVENIO_PARTICIPACION_FIRMADO
  INSTRUCCION_EJECUTOR
  NOMBRAMIENTO_EJECUTOR
  AVALUO_PROTOCOLIZADO
  EXPEDIENTE_PLD
  ALTA_CONDUSEF
  PODER_NOTARIAL_SOFOM
  // General
  REPORTE_VISITA
  DICTAMEN_CORPORATIVO
  DICTAMEN_GARANTIAS
  CONSULTA_LEGAL
  OTRO
}

enum TipoSolicitud {
  SOL_01_DICTAMEN_PREAUTORIZACION
  SOL_02_CLG_RPP
  SOL_03_DICTAMEN_CORPORATIVO
  SOL_04_DICTAMEN_GARANTIAS
  SOL_05_AVALUO
  SOL_06_RATIFICACION_CONTINUIDAD
  SOL_07_CONTRATO_ESCRITURA
  SOL_08_PROGRAMACION_FIRMA
}

enum StatusSolicitud {
  PENDIENTE
  EN_PROCESO
  COMPLETADA
  RECHAZADA
}

enum TipoHistorial {
  CREACION
  CAMBIO_ESTATUS
  AVANCE_BLOQUE
  RETROCESO_BLOQUE
  CARGA_DOCUMENTO
  CAMBIO_CHECKLIST
  SOLICITUD_GENERADA
  SOLICITUD_RESPONDIDA
  PAGO_REGISTRADO
  COMENTARIO
  MORA_ACTIVADA
  AJUSTE_MORATORIO
  OTRO
}

enum TipoNotificacion {
  SOLICITUD_RECIBIDA
  SOLICITUD_COMPLETADA
  DOCUMENTO_CARGADO
  BLOQUE_AVANZADO
  SLA_PROXIMO
  SLA_VENCIDO
  PAGO_REGISTRADO
  MORA_ACTIVADA
  COMENTARIO
}

// ─── MODELOS PRINCIPALES ─────────────────────────────────────────────────────

model Usuario {
  id            String    @id @default(cuid())
  nombre        String
  email         String    @unique
  password      String
  rol           Rol       @default(OPERADOR)
  activo        Boolean   @default(true)
  creadoEn      DateTime  @default(now())

  operacionesAsignadas Operacion[]           @relation("EjecutivoOperacion")
  operacionesCreadas   Operacion[]           @relation("CreadoPorOperacion")
  bloquesResponsable   BloqueOperacion[]     @relation("ResponsableBloque")
  checklistItems       ChecklistItem[]       @relation("CompletadoPorChecklist")
  documentosCargados   Documento[]           @relation("CargadoPorDocumento")
  documentosValidados  Documento[]           @relation("ValidadoPorDocumento")
  solicitudesGeneradas Solicitud[]           @relation("GeneradaPorSolicitud")
  solicitudesDirigidas Solicitud[]           @relation("DirigidaASolicitud")
  comentarios          ComentarioSolicitud[]
  historial            HistorialMovimiento[] @relation("UsuarioHistorial")
  notificaciones       Notificacion[]
  pagosRegistrados     PagoMensual[]         @relation("RegistradoPorPago")
  bitacora             Bitacora[]
}

// ─── ACREDITADO (catálogo separado de Operacion) ──────────────────────────────

model Acreditado {
  id          String         @id @default(cuid())
  nombre      String
  rfc         String?
  telefono    String?
  email       String?
  direccion   String?
  tipoPersona TipoAcreditado @default(PF)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  operaciones Operacion[]
}

// ─── INVERSIONISTA (catálogo global — desacoplado de Operacion) ───────────────

model Inversionista {
  id           String   @id @default(cuid())
  nombre       String
  rfc          String?
  banco        String?
  cuentaClabe  String?  @unique
  email        String?
  telefono     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  participaciones Participacion[]
}

// ─── PARTICIPACION (inversionista × operacion) ────────────────────────────────

model Participacion {
  id                      String        @id @default(cuid())
  operacionId             String
  inversionistaId         String
  porcentajeParticipacion Decimal       @db.Decimal(6,4)
  montoAportado           Decimal       @db.Decimal(14,2)
  tasaNeta                Decimal       @db.Decimal(6,4)
  esSofom                 Boolean       @default(false)
  orden                   Int           @default(0)
  fechaAlta               DateTime      @default(now())

  operacion               Operacion     @relation(fields: [operacionId],     references: [id])
  inversionista           Inversionista @relation(fields: [inversionistaId], references: [id])

  @@unique([operacionId, inversionistaId])
}

// ─── OPERACION ────────────────────────────────────────────────────────────────

model Operacion {
  id            String    @id @default(cuid())
  folio         String    @unique
  nombre        String
  producto      Producto
  status        StatusOp  @default(PROSPECTO)
  bloqueActual  Int       @default(1)

  // Acreditado (FK al catálogo)
  acreditadoId  String
  acreditado    Acreditado @relation(fields: [acreditadoId], references: [id])

  // Usuarios
  ejecutivoId   String
  ejecutivo     Usuario   @relation("EjecutivoOperacion", fields: [ejecutivoId], references: [id])
  creadoPorId   String
  creadoPor     Usuario   @relation("CreadoPorOperacion", fields: [creadoPorId], references: [id])

  // Parámetros financieros — Decimal
  monto             Decimal  @db.Decimal(14,2)
  tasaAnual         Decimal  @db.Decimal(6,4)
  plazoMeses        Int
  fechaPrimerPago   DateTime
  comisionApertura  Decimal  @default(0.0300) @db.Decimal(6,4)
  costosFijos       Decimal  @default(0)      @db.Decimal(14,2)

  // IVA / mora / gracia — required manual por operación
  aplicaIva            Boolean @default(true)
  tasaIva              Decimal @default(0.1600) @db.Decimal(5,4)
  tasaMoratoriaAnual   Decimal @db.Decimal(6,4)        // required, sin default
  diasGracia           Int     @default(3)
  capitalizaMoratorios Boolean @default(false)

  // Solo STPB
  spreadSofom          Decimal? @db.Decimal(6,4)
  adminFideicomiso     Decimal? @db.Decimal(6,4)
  comisionCobranza     Decimal? @db.Decimal(6,4)
  sofomComoAcreditante Boolean  @default(false)
  sofomMonto           Decimal? @db.Decimal(14,2)
  sofomTasaNeta        Decimal? @db.Decimal(6,4)

  // Extras
  notas         String?
  folioPld      String?
  valorInmueble Decimal? @db.Decimal(14,2)
  ltv           Decimal? @db.Decimal(6,4)

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  // Relaciones
  participaciones Participacion[]
  bloques         BloqueOperacion[]
  pagos           PagoMensual[]
  documentos      Documento[]
  solicitudes     Solicitud[]
  historial       HistorialMovimiento[]
  notificaciones  Notificacion[]
}

// ─── BLOQUE / CHECKLIST ───────────────────────────────────────────────────────

model BloqueOperacion {
  id            String        @id @default(cuid())
  operacionId   String
  operacion     Operacion     @relation(fields: [operacionId], references: [id])
  numeroBloque  Int
  status        StatusBloque  @default(PENDIENTE)
  resultado     StatusBloque?
  condiciones   String?
  motivoRechazo String?
  fechaInicio   DateTime?
  fechaCierre   DateTime?
  slaHoras      Int?
  responsableId String?
  responsable   Usuario?      @relation("ResponsableBloque", fields: [responsableId], references: [id])
  creadoEn      DateTime      @default(now())
  actualizadoEn DateTime      @updatedAt

  checklistItems ChecklistItem[]

  @@unique([operacionId, numeroBloque])
}

model ChecklistItem {
  id              String          @id @default(cuid())
  bloqueId        String
  bloque          BloqueOperacion @relation(fields: [bloqueId], references: [id])
  descripcion     String
  categoria       String?
  completado      Boolean         @default(false)
  completadoPorId String?
  completadoPor   Usuario?        @relation("CompletadoPorChecklist", fields: [completadoPorId], references: [id])
  fechaCompletado DateTime?
  nota            String?
  orden           Int             @default(0)
  creadoEn        DateTime        @default(now())
}

// ─── DOCUMENTOS ───────────────────────────────────────────────────────────────

model Documento {
  id              String          @id @default(cuid())
  operacionId     String
  operacion       Operacion       @relation(fields: [operacionId], references: [id])
  tipo            TipoDocumento
  nombre          String
  status          StatusDocumento @default(PENDIENTE)
  archivoUrl      String?
  tamano          Int?
  seccion         String
  bloqueNumero    Int?

  cargadoPorId    String?
  cargadoPor      Usuario?        @relation("CargadoPorDocumento", fields: [cargadoPorId], references: [id])
  fechaCarga      DateTime?
  validadoPorId   String?
  validadoPor     Usuario?        @relation("ValidadoPorDocumento", fields: [validadoPorId], references: [id])
  fechaValidacion DateTime?
  nota            String?

  creadoEn        DateTime        @default(now())
  actualizadoEn   DateTime        @updatedAt
}

// ─── SOLICITUDES ──────────────────────────────────────────────────────────────

model Solicitud {
  id              String          @id @default(cuid())
  folio           String          @unique
  operacionId     String
  operacion       Operacion       @relation(fields: [operacionId], references: [id])
  tipo            TipoSolicitud
  descripcion     String?
  status          StatusSolicitud @default(PENDIENTE)
  fechaLimite     DateTime?
  fechaCompletada DateTime?
  bloqueNumero    Int?

  generadaPorId   String
  generadaPor     Usuario         @relation("GeneradaPorSolicitud", fields: [generadaPorId], references: [id])
  dirigidaAId     String
  dirigidaA       Usuario         @relation("DirigidaASolicitud", fields: [dirigidaAId], references: [id])

  comentarios     ComentarioSolicitud[]
  creadoEn        DateTime        @default(now())
  actualizadoEn   DateTime        @updatedAt
}

model ComentarioSolicitud {
  id          String    @id @default(cuid())
  solicitudId String
  solicitud   Solicitud @relation(fields: [solicitudId], references: [id])
  usuarioId   String
  usuario     Usuario   @relation(fields: [usuarioId], references: [id])
  texto       String
  archivoUrl  String?
  creadoEn    DateTime  @default(now())
}

// ─── HISTORIAL (por operación) ────────────────────────────────────────────────

model HistorialMovimiento {
  id          String        @id @default(cuid())
  operacionId String
  operacion   Operacion     @relation(fields: [operacionId], references: [id])
  usuarioId   String
  usuario     Usuario       @relation("UsuarioHistorial", fields: [usuarioId], references: [id])
  tipo        TipoHistorial
  descripcion String
  detalle     String?
  creadoEn    DateTime      @default(now())
}

// ─── NOTIFICACIONES ───────────────────────────────────────────────────────────

model Notificacion {
  id          String           @id @default(cuid())
  usuarioId   String
  usuario     Usuario          @relation(fields: [usuarioId], references: [id])
  tipo        TipoNotificacion
  titulo      String
  descripcion String
  operacionId String?
  operacion   Operacion?       @relation(fields: [operacionId], references: [id])
  solicitudId String?
  leida       Boolean          @default(false)
  creadoEn    DateTime         @default(now())
}

// ─── PAGO MENSUAL ─────────────────────────────────────────────────────────────

model PagoMensual {
  id               String    @id @default(cuid())
  operacionId      String
  operacion        Operacion @relation(fields: [operacionId], references: [id])
  numeroPago       Int
  fechaVencimiento DateTime
  fechaPagoReal    DateTime?

  // Montos — Decimal(14,2)
  capitalTotal           Decimal  @db.Decimal(14,2)
  interesTotal           Decimal  @db.Decimal(14,2)
  iva                    Decimal  @default(0) @db.Decimal(14,2)
  pagoTotal              Decimal  @db.Decimal(14,2)
  saldo                  Decimal  @db.Decimal(14,2)

  status                 StatusPago @default(PENDIENTE)
  montoPagado            Decimal?   @db.Decimal(14,2)
  interesOrdinarioPagado Decimal?   @db.Decimal(14,2)
  interesesMoratorios    Decimal    @default(0) @db.Decimal(14,2)
  ivaMoratorios          Decimal    @default(0) @db.Decimal(14,2)
  diasAtraso             Int        @default(0)
  diasMora               Int?

  comprobanteUrl    String?
  registradoPorId   String?
  registradoPor     Usuario?  @relation("RegistradoPorPago", fields: [registradoPorId], references: [id])
  notas             String?

  motivoCondonacion String?
  condonadoPor      String?
  montoOriginal     Decimal?  @db.Decimal(14,2)

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
}

// ─── BITÁCORA (auditoría global PLD) ─────────────────────────────────────────

model Bitacora {
  id          String   @id @default(cuid())
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
  accion      String
  entidad     String
  entidadId   String?
  payloadJson Json?
  ip          String?
  createdAt   DateTime @default(now())

  @@index([entidad, entidadId])
  @@index([createdAt])
}
